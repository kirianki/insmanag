# .env

# API Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Theme Configuration (using HSL values for better color manipulation)
# Example: A Professional Blue Theme
VITE_THEME_PRIMARY=217 91% 60%
VITE_THEME_SECONDARY=215 28% 47%
VITE_THEME_BACKGROUND=220 13% 95%
VITE_THEME_FOREGROUND=220 13% 15% # For text
VITE_THEME_BORDER_RADIUS=0.5rem